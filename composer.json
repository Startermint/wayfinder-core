{
    "name": "wayfinder/core",
    "description": "Wayfinder, an explicit, no-magic PHP framework core.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/Startermint/wayfinder-core",
    "keywords": [
        "framework",
        "http",
        "routing",
        "stackmint",
        "wayfinder"
    ],
    "support": {
        "issues": "https://github.com/Startermint/wayfinder-core/issues",
        "source": "https://github.com/Startermint/wayfinder-core"
    },
    "require": {
        "php": "^8.2",
        "illuminate/config": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/queue": "^12.0",
        "illuminate/redis": "^12.0",
        "pda/pheanstalk": "^7.0 || ^8.0",
        "predis/predis": "^3.2",
        "symfony/http-foundation": "^7.0",
        "nesbot/carbon": "^3.0",
        "league/flysystem": "^3.0",
        "monolog/monolog": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Wayfinder\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload-dev": {
        "psr-4": {
            "Wayfinder\\Tests\\": "tests/"
        }
    }
}
